# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# JWT_SECRET: Secret key for JWT token signing (change in production)
JWT_SECRET="EXAM_PROCTOR_SECRET_2026_CHANGE_ME"

# API_KEYS: Comma-separated API keys for Moodle plugin authentication
# The plugin can use these instead of JWT for sending telemetry events
API_KEYS="moodle_plugin_key_1,moodle_plugin_key_2"

# PORT: Server port (default: 3000)
PORT=3000

# NODE_ENV: Environment mode (development | production)
NODE_ENV=development
